# ============================================================
# MiroEval — Unified Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Lines starting with # are optional or have defaults.
# ============================================================

# ── Core LLM (required for quality + process evaluation) ──────────────────
OPENAI_API_KEY=""
OPENAI_BASE_URL=""                      # Optional: custom OpenAI-compatible endpoint
OPENROUTER_API_KEY=""                   # Optional: for OpenRouter-hosted models

# ── Search APIs (required for factual evaluation) ─────────────────────────
SERPER_API_KEY=""
JINA_API_KEY=""

# ── MiroEval evaluation settings (all optional, shown with defaults) ──────
# MIROEVAL_QUALITY_MODEL="gpt-5.1"
# MIROEVAL_QUALITY_API_TYPE="openai"
# MIROEVAL_QUALITY_MAX_WORKERS=20
# MIROEVAL_PROCESS_MODEL="gpt-5.2"
# MIROEVAL_PROCESS_API_TYPE="openai"
# MIROEVAL_PROCESS_MAX_WORKERS=10
# MIROEVAL_FACTUAL_MAX_CONCURRENT=10
# MIROEVAL_FACTUAL_MAX_CHUNKS=10

# ── MiroFlow / Factual Eval (optional, for advanced configuration) ────────
# OAI_MIROTHINKER_BASE_URL=""
# OAI_MIROTHINKER_API_KEY=""
# SUMMARY_LLM_BASE_URL=""
# SUMMARY_LLM_API_KEY=""
# SUMMARY_LLM_MODEL_NAME="gpt-5-nano"
# E2B_API_KEY=""                        # Code sandbox for agents

# ── Vision MCP Server (optional) ──────────────────────────────────────────
